<div class="jetset-overlay" id="jetset-overlay" role="dialog" aria-modal="true" aria-label="Join the Jet-Set Club" aria-hidden="true">
  <div class="jetset-modal" id="jetset-modal">
    <button class="jetset-modal__close" id="jetset-close" aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="2" y1="2" x2="16" y2="16"/>
        <line x1="16" y1="2" x2="2" y2="16"/>
      </svg>
    </button>

    {%- if section.settings.logo != blank -%}
      <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ section.settings.brand_name }}" style="height:48px;width:auto;margin-bottom:0.35rem;">
    {%- else -%}
      <img src="{{ 'IMG_8569.jpeg' | asset_url }}" alt="{{ section.settings.brand_name }}" style="height:48px;width:auto;margin-bottom:0.35rem;">
    {%- endif -%}

    <span class="jetset-modal__eyebrow">{{ section.settings.brand_name }} &nbsp;·&nbsp; Est. 2026</span>
    <div class="jetset-modal__rule"></div>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.body_text }}</p>

    <div id="popup-form-block">
      <form id="popup-waitlist-form" novalidate aria-label="Join waitlist">
        <div class="form-group">
          <label class="form-label" for="popup-field-name">First Name</label>
          <input class="form-input"
                 type="text"
                 id="popup-field-name"
                 name="first-name"
                 placeholder="Your first name"
                 autocomplete="given-name"
                 required>
          <span class="form-error" id="popup-err-name" role="alert">Please enter your first name.</span>
        </div>
        <div class="form-group">
          <label class="form-label" for="popup-field-email">Email Address</label>
          <input class="form-input"
                 type="email"
                 id="popup-field-email"
                 name="email"
                 placeholder="your@email.com"
                 autocomplete="email"
                 required>
          <span class="form-error" id="popup-err-email" role="alert">Please enter a valid email address.</span>
        </div>
        <button type="submit" class="form-submit" id="popup-submit-btn">
          Unlock Private Access
        </button>
      </form>
      <p class="form-privacy">No spam. Ever. Your information is kept strictly private.</p>
    </div>

    <div class="success-state" id="popup-success-block" aria-live="polite">
      <div class="success-icon" aria-hidden="true">✓</div>
      <h3>Welcome to the Club.</h3>
      <p>
        Your private access code <span class="success-code">JETSET15</span> has been
        registered to your inbox. Early entry details will arrive in July.
      </p>
      <p style="margin-top: 1rem; font-size: 0.8rem; color: var(--text-muted);">
        Follow along on <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" style="color:var(--navy);">Instagram</a>
        and <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener noreferrer" style="color:var(--navy);">TikTok</a> for behind-the-scenes from the Amalfi.
      </p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Jet-Set Club Popup",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "Katerina's Kinis"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Popup heading",
      "default": "Join the Jet-Set Club"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Popup body",
      "default": "Our inaugural Amalfi Edit is strictly limited. Join the private club for 24-hour early access, size-reservation priority, and a 15% code applied to your first piece."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/katerinaskinis/"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL",
      "default": "https://www.tiktok.com/@katerinaskinis"
    }
  ]
}
{% endschema %}
